#
# Single web app runtime
# The backend API and browser dashboard are both served on this same port.
#
PORT=4100
PUBLIC_APP_URL=http://localhost:4100

#
# Dashboard runtime config
# Leave DASHBOARD_API_BASE_URL blank when the dashboard is served by this backend.
# DASHBOARD_PUBLIC_DIR is optional because the backend auto-detects local and Docker paths.
#
DASHBOARD_PUBLIC_DIR=
DASHBOARD_API_BASE_URL=
APP_NAME=Fleebee Dispatch Desk
BOARD_REFRESH_INTERVAL_MS=5000
MESSAGE_RESULT_TIMEOUT_MS=18000
MESSAGE_RESULT_POLL_MS=1500

#
# Backend storage and API behavior
#
DATABASE_URL="file:./fleebee.db"
CORS_ALLOW_ORIGIN=*
JOB_STALE_MS=60000
SCHEDULE_POLL_MS=30000
PHONE_HEARTBEAT_STALE_MS=20000
DUPLICATE_WINDOW_MS=600000

#
# SMS dispatch protection
#
SMS_SEND_PASSWORD=1234

#
# Gateway identity and phone defaults
#
PHONE_STATE_ID=android-home-gateway
SMS_GATEWAY_MODE=test-routing
SMS_GATEWAY_TARGET_NUMBER=0788690545
SMS_GATEWAY_FIXED_LOCATION=Home gateway
SMS_GATEWAY_BATTERY_POLICY=Needs manual unrestricted setting on Samsung
SMS_GATEWAY_NETWORK_LABEL=Wi-Fi / mobile fallback
SMS_GATEWAY_DEVICE_ID=android-home-gateway
